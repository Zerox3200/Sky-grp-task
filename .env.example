# Copy to `.env` for local development (with XAMPP MySQL running)
# cp .env.example .env

PORT=5001

secretkey=CheeseCakeForSkyGroup
saltRound=8

# XAMPP MySQL defaults
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=sky_grp
DB_USER=root
DB_PASSWORD=root

# Email (optional — required for order confirmation emails)
Email=test@test.com
Emailpassword=test

REDIS_URL=redis://127.0.0.1:6379
CACHE_KEY_PREFIX=sky-grp
